# === LLM 服务配置 ===
# 服务商：openrouter
LLM_PROVIDER=openrouter
# OpenRouter API Key（从 https://openrouter.ai/keys 获取）
# 支持多个 Key，用英文逗号分隔，失败时自动轮询下一个
OPENROUTER_API_KEY=sk-or-v1-key1,sk-or-v1-key2
# OpenRouter Base URL（一般无需修改）
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 使用的模型名称（参考 https://openrouter.ai/models）
LLM_MODEL=anthropic/claude-sonnet-4

# === LLM 调用参数 ===
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# === 重试策略 ===
# 单个 Key 最大重试次数
LLM_MAX_RETRIES=3
# 重试间隔（秒）
LLM_RETRY_INTERVAL=2

# === 输出配置 ===
# 报告输出目录（相对于项目根目录，或绝对路径）
OUTPUT_DIR=output
